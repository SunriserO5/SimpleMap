{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build (MSVC)",
            "type": "shell",
            "command": "cmd",
            "args": [
                "/c",
                "call \"C:\\Program Files\\Microsoft Visual Studio\\2022\\Community\\VC\\Auxiliary\\Build\\vcvars64.bat\" && cd /d \"${workspaceFolder}\" && _compile_gui.bat"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [],
            "detail": "使用 MSVC 编译并运行"
        },
        {
            "label": "Compile only (MSVC)",
            "type": "shell",
            "command": "cmd",
            "args": [
                "/c",
                "call \"C:\\Program Files\\Microsoft Visual Studio\\2022\\Community\\VC\\Auxiliary\\Build\\vcvars64.bat\" && cd /d \"${workspaceFolder}\" && cl /EHsc /c gui.cpp /Fogui.obj /I\"thirdparty\\raylib\\raylib-6.0_win64_msvc16\\include\" /W4 /D \"WITH_GUI\" /utf-8"
            ],
            "group": "build",
            "problemMatcher": {
                "fileLocation": "absolute",
                "pattern": {
                    "regexp": "^(.*)\\((\\d+)\\):\\s+(error|warning)\\s+(\\w+):\\s+(.*)$",
                    "file": 1,
                    "line": 2,
                    "severity": 3,
                    "code": 4,
                    "message": 5
                }
            },
            "detail": "仅编译 gui.cpp 检查语法错误"
        }
    ]
}
